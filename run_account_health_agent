# run_account_health_agent.py
from __future__ import annotations

import argparse
import os

from reader_databricks_health import load_databricks_context
from rules_engine_health import evaluate_all
from writer_account_health import write_account_health_output


def _ensure_mnt_data_path(ctx_hash_name: str, out_arg: str | None) -> str:
    """
    ChatGPT attachments must come from /mnt/data.
    - If out_arg is None -> /mnt/data/<HashName> - Account Health Analysis.xlsm
    - If out_arg is a directory -> that directory under /mnt/data + auto filename
    - If out_arg is a filename/path -> force into /mnt/data with same basename
    """
    base_name = f"{ctx_hash_name} - Account Health Analysis.xlsm"

    if not out_arg:
        return os.path.join("/mnt/data", base_name)

    # If user passed a directory, save inside it (but force /mnt/data root)
    if out_arg.endswith("/") or out_arg.endswith("\\") or os.path.isdir(out_arg):
        return os.path.join("/mnt/data", os.path.basename(out_arg.rstrip("/\\") or "mnt"), base_name)

    # Otherwise treat as file path; force it into /mnt/data by basename
    fname = os.path.basename(out_arg)
    if not fname.lower().endswith(".xlsm"):
        fname += ".xlsm"
    return os.path.join("/mnt/data", fname)


def main():
    parser = argparse.ArgumentParser(description="CoE Account Health Agent")
    parser.add_argument("--export", required=True, help="Path to Databricks export .xlsx")
    parser.add_argument("--template", required=True, help="Path to CoE_Account_Health_Analysis_Templates.xlsm")
    parser.add_argument("--out", required=False, default=None, help="Output path (.xlsm). Will be forced to /mnt/data/")
    args = parser.parse_args()

    export_path = args.export
    template_path = args.template

    if not os.path.exists(export_path):
        raise FileNotFoundError(f"Export not found: {export_path}")
    if not os.path.exists(template_path):
        raise FileNotFoundError(f"Template not found: {template_path}")

    ctx = load_databricks_context(export_path)

    results, ctx = evaluate_all(ctx)

    # Force output to /mnt/data so the file can be attached/downloaded
    out_path = _ensure_mnt_data_path(ctx.hash_name, args.out)

    # Ensure directory exists
    os.makedirs(os.path.dirname(out_path), exist_ok=True)

    write_account_health_output(
        template_path=template_path,
        output_path=out_path,
        ctx=ctx,
        results=results,
    )

    # Sanity check (prevents “file not available”)
    if (not os.path.exists(out_path)) or os.path.getsize(out_path) == 0:
        raise RuntimeError(f"Output file was not created or is empty: {out_path}")

    print("DONE")
    print(f"Output: {out_path}")
    print(f"Account: {ctx.hash_name}")
    print(f"Window: {ctx.window_str} | Downloaded: {ctx.downloaded_dt}")


if __name__ == "__main__":
    main()

def ok(what: str = "", src: str = "", note: str = "") -> cfg.ControlResult:
    return cfg.ControlResult(status=cfg.STATUS_OK, what_we_saw=what, data_source=src, note=note)

def partial(what: str, src: str = "", note: str = "") -> cfg.ControlResult:
    if not what:
        what = "Observed: Partial signal detected."
    return cfg.ControlResult(status=cfg.STATUS_PARTIAL, what_we_saw=what, data_source=src, note=note)

def flag(what: str, src: str = "", note: str = "") -> cfg.ControlResult:
    if not what:
        raise ValueError("FLAG requires a non-empty what_we_saw.")
    return cfg.ControlResult(status=cfg.STATUS_FLAG, what_we_saw=what, data_source=src, note=note)

def _to_float(x) -> Optional[float]:
    if x is None:
        return None
    if isinstance(x, (int, float)) and not pd.isna(x):
        return float(x)
    s = str(x).strip()
    if not s or s.lower() in ("nan", "none", "null", "-"):
        return None
    # currency / commas / percent
    s = s.replace("$", "").replace("€", "").replace("£", "")
    s = s.replace(",", "").replace(" ", "")
    # handle percent strings "12%"
    if s.endswith("%"):
        try:
            return float(s[:-1]) / 100.0
        except Exception:
            return None
    # handle "30k"
    m = re.match(r"^([0-9]*\.?[0-9]+)k$", s, flags=re.I)
    if m:
        try:
            return float(m.group(1)) * 1000.0
        except Exception:
            return None
    try:
        return float(s)
    except Exception:
        return None

def _pct_str(x: float, decimals: int = 1) -> str:
    return f"{x*100:.{decimals}f}%"

def _money_str(x: float) -> str:
    # simple formatting
    return f"{x:,.0f}"

def _excel_row_to_df_index(excel_row: int) -> int:
    # With header=5, df row 0 corresponds to Excel row 7.
    return excel_row - 7

def _col_letter_to_zero_index(letter: str) -> int:
    letter = letter.upper().strip()
    n = 0
    for ch in letter:
        n = n * 26 + (ord(ch) - ord('A') + 1)
    return n - 1

def _read_cell_by_pos(df: pd.DataFrame, excel_col_letter: str, excel_row: int) -> Optional[float]:
    if df is None or df.empty:
        return None
    r = _excel_row_to_df_index(excel_row)
    c = _col_letter_to_zero_index(excel_col_letter)
    if r < 0 or c < 0:
        return None
    if r >= len(df.index) or c >= len(df.columns):
        return None
    return _to_float(df.iloc[r, c])

def _read_str_cell_by_pos(df: pd.DataFrame, excel_col_letter: str, excel_row: int) -> str:
    if df is None or df.empty:
        return ""
    r = _excel_row_to_df_index(excel_row)
    c = _col_letter_to_zero_index(excel_col_letter)
    if r < 0 or c < 0:
        return ""
    if r >= len(df.index) or c >= len(df.columns):
        return ""
    v = df.iloc[r, c]
    return "" if v is None or (isinstance(v, float) and pd.isna(v)) else str(v).strip()

def _parse_months_from_text(text: str) -> set[int]:
    """
    Extracts seasonality months from free text.
    Supports:
      - "Nov-Dec", "November to December"
      - "6-8", "Jun-Aug"
      - "Prime Day July" (maps July=7)
      - "Q4" -> {10,11,12}
      - "Q1" -> {1,2,3} etc.
    """
    if not text:
        return set()
    t = text.lower()

    # quarters
    q_map = {
        "q1": {1,2,3},
        "q2": {4,5,6},
        "q3": {7,8,9},
        "q4": {10,11,12},
    }
    months = set()
    for q, ms in q_map.items():
        if q in t:
            months |= ms

    name_map = {
        "jan": 1, "january": 1,
        "feb": 2, "february": 2,
        "mar": 3, "march": 3,
        "apr": 4, "april": 4,
        "may": 5,
        "jun": 6, "june": 6,
        "jul": 7, "july": 7,
        "aug": 8, "august": 8,
        "sep": 9, "sept": 9, "september": 9,
        "oct": 10, "october": 10,
        "nov": 11, "november": 11,
        "dec": 12, "december": 12,
    }

    # numeric ranges "6-8"
    for m in re.finditer(r"\b(1[0-2]|[1-9])\s*-\s*(1[0-2]|[1-9])\b", t):
        a = int(m.group(1)); b = int(m.group(2))
        if a <= b:
            months |= set(range(a, b+1))

    # named ranges "nov-dec"
    for m in re.finditer(r"\b([a-z]{3,9})\s*-\s*([a-z]{3,9})\b", t):
        a = name_map.get(m.group(1)); b = name_map.get(m.group(2))
        if a and b and a <= b:
            months |= set(range(a, b+1))

    # single month names
    for k, v in name_map.items():
        if re.search(rf"\b{k}\b", t):
            months.add(v)

    # Prime Day (assume July if not stated)
    if "prime day" in t and 7 not in months:
        months.add(7)

    return {m for m in months if 1 <= m <= 12}

def _extract_budget_from_text(text: str) -> Optional[float]:
    """
    Extract budget/spend target from AM7 free text.
    Examples:
      "Budget: $50,000" -> 50000
      "Monthly budget 30k" -> 30000
      "Spend target 25000" -> 25000
    """
    if not text:
        return None
    t = text.lower()

    # only attempt if keyword present
    if not any(k in t for k in ["budget", "spend target", "budget cap", "monthly budget", "spend"]):
        return None

    # look for patterns after keywords
    patterns = [
        r"(budget|monthly budget|budget cap|spend target)\s*[:=]?\s*\$?\s*([0-9]{1,3}(?:,[0-9]{3})+|[0-9]*\.?[0-9]+k?|[0-9]+)",
    ]
    for pat in patterns:
        m = re.search(pat, t, flags=re.I)
        if m:
            raw = m.group(2).strip()
            return _to_float(raw)
    return None


def _latest_full_month_anchor(ctx: DatabricksContext) -> Optional[pd.Timestamp]:
    """
    Determine latest full month based on ctx.window_end.
    If window_end is day 1 -> prior month is latest full month.
    Return timestamp at month start (YYYY-MM-01).
    """
    if not ctx.window_end:
        return None
    we = pd.Timestamp(ctx.window_end)
    if we.day == 1:
        # previous month start
        return (we - pd.offsets.MonthBegin(1))
    # month start of window_end month
    return pd.Timestamp(year=we.year, month=we.month, day=1)

def _get_last_n_full_month_rows(df_monthly: pd.DataFrame, ctx: DatabricksContext, n: int, month_col_index: int = 0) -> Optional[pd.DataFrame]:
    """
    From a monthly table, take last n rows up to latest full month.
    Uses column A (index 0) as month identifier.
    """
    if df_monthly is None or df_monthly.empty:
        return None
    # extract month column values as dates
    months = pd.to_datetime(df_monthly.iloc[:, month_col_index], errors="coerce")
    tmp = df_monthly.copy()
    tmp["_month"] = months.dt.to_period("M").dt.to_timestamp()

    anchor = _latest_full_month_anchor(ctx)
    if anchor is None:
        return None

    tmp = tmp[tmp["_month"] <= anchor].sort_values("_month")
    if tmp.empty:
        return None
    return tmp.tail(n)


def _apply_seasonality_thresholds(ctx: DatabricksContext, months_involved: List[pd.Timestamp], base_flag: float, base_partial: float) -> Tuple[float, float]:
    """
    For MoM/QoQ only:
      base_flag=-0.10, base_partial=-0.05
    If any involved month is seasonal -> relax:
      flag=-0.15, partial=-0.10
    Returns (flag_threshold, partial_threshold) where thresholds are negative numbers.
    """
    if not ctx.season_months:
        return (base_flag, base_partial)
    for m in months_involved:
        if int(m.month) in ctx.season_months:
            return (-0.15, -0.10)
    return (base_flag, base_partial)



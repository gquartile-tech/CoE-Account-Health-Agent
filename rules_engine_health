        return flag("Observed: Monthly YoY tab missing/insufficient to compute last-3-month average sales for fee ratio.", src)

    sales_vals = [_to_float(x) for x in list(last3.iloc[:, 1])]  # column B index 1
    if any(v is None for v in sales_vals):
        return flag("Observed: Total sales values missing in 05_Monthly_Sales_YoY_Comparison column B for fee ratio computation.", src)

    avg_sales = sum(sales_vals) / 3.0
    if avg_sales == 0:
        return flag("Observed: 3-month average sales is zero/invalid; cannot compute fee ratio.", src)

    ratio = float(ctx.mrr_fee) / avg_sales

    what = f"Observed: Monthly fee = {_money_str(float(ctx.mrr_fee))} and the 3-month average revenue = {_money_str(avg_sales)}, resulting in a fee-to-sales ratio of {_pct_str(ratio)}."
    if ratio < 0.10:
        return ok(what, src)
    if ratio <= 0.15:
        return partial(what, src)
    return flag(what, src)


def _bench_compare_directional(our: float, bench: float, direction: str) -> float:
    """
    direction:
      - 'higher_worse' : deviation only if our > bench
      - 'lower_worse'  : deviation only if our < bench
      - 'abs'          : absolute deviation
    returns deviation ratio (e.g., 0.12 = +12%)
    """
    if bench == 0:
        return float("inf")
    dev = (our - bench) / bench
    if direction == "higher_worse":
        return max(dev, 0.0)
    if direction == "lower_worse":
        return max(-dev, 0.0)
    return abs(dev)

def _bench_status(dev: float, ok_th: float, partial_th: float) -> str:
    # dev is positive ratio
    if dev < ok_th:
        return cfg.STATUS_OK
    if dev <= partial_th:
        return cfg.STATUS_PARTIAL
    return cfg.STATUS_FLAG


def eval_C006(ctx: DatabricksContext) -> cfg.ControlResult:
    df02 = get_dataset(ctx, "KPI_RANGE")
    src = "02_Date_Range_KPIs__Date_Range_!G7 vs User Budget (input) + CS AM7 budget presence"
    if df02 is None or df02.empty:
        return flag("Observed: Date range KPI tab missing; cannot evaluate budget pacing.", src)

    spend = _read_cell_by_pos(df02, "G", 7)
    if spend is None:
        return flag("Observed: Spend value missing in 02_Date_Range_KPIs__Date_Range_ (G7).", src)

    if ctx.user_budget is None:
        return flag("Observed: Budget input is required to evaluate C006 (user_budget not provided).", src)

    # Requirement A: budget must be documented in CS AM7
    if ctx.budget_target_from_cs is None:
        return flag("Observed: Budget target not documented in Client Success context (AM7).", src)

    budget = float(ctx.user_budget)
    if budget == 0:
        return flag("Observed: Provided budget is zero/invalid; cannot evaluate pacing.", src)

    dev = (spend - budget) / budget
    abs_dev = abs(dev)

    if abs_dev <= 0.10:
        return ok(f"Observed: Spend = {_money_str(spend)} vs budget target = {_money_str(budget)} (Δ {_pct_str(dev)}).", src)
    if abs_dev <= 0.20:
        return partial(f"Observed: Spend = {_money_str(spend)} vs budget target = {_money_str(budget)} (Δ {_pct_str(dev)}).", src)
    return flag(f"Observed: Spend = {_money_str(spend)} vs budget target = {_money_str(budget)} (Δ {_pct_str(dev)}).", src)

def eval_C007(ctx: DatabricksContext) -> cfg.ControlResult:

def eval_C001(ctx: DatabricksContext) -> cfg.ControlResult:
    df = get_dataset(ctx, "L24M_MONTHLY")
    src = "04_L24M_Monthly_Performance_Sum!B (TotalSales)"
    last2 = _get_last_n_full_month_rows(df, ctx, n=2, month_col_index=0)
    if last2 is None or len(last2) < 2:
        return flag("Observed: Monthly performance data missing or insufficient to compute MoM revenue growth.", src)
    # TotalSales column B => index 1
    try:
        m0 = last2.iloc[-1]["_month"]
        m1 = last2.iloc[-2]["_month"]
        rev0 = _to_float(last2.iloc[-1, 1])
        rev1 = _to_float(last2.iloc[-2, 1])
    except Exception:
        return flag("Observed: Unable to read TotalSales from 04_L24M_Monthly_Performance_Sum column B.", src)

    if rev0 is None or rev1 is None or rev1 == 0:
        return flag("Observed: TotalSales values missing/invalid for MoM revenue calculation.", src)

    mom = (rev0 - rev1) / rev1
    flag_th, partial_th = _apply_seasonality_thresholds(ctx, [pd.Timestamp(m0), pd.Timestamp(m1)], base_flag=-0.10, base_partial=-0.05)

    if mom <= flag_th:
        return flag(f"Observed: Revenue changed {_pct_str(mom)} vs prior month ({_money_str(rev1)} → {_money_str(rev0)}) using the latest full month available.", src)
    if mom <= partial_th:
        return partial(f"Observed: Revenue changed {_pct_str(mom)} vs prior month ({_money_str(rev1)} → {_money_str(rev0)}) using the latest full month available.", src)
    return ok(f"Observed: Revenue changed {_pct_str(mom)} vs prior month ({_money_str(rev1)} → {_money_str(rev0)}) using the latest full month available.", src)

def eval_C002(ctx: DatabricksContext) -> cfg.ControlResult:
    df = get_dataset(ctx, "L24M_MONTHLY")
    src = "04_L24M_Monthly_Performance_Sum!B (TotalSales)"
    last6 = _get_last_n_full_month_rows(df, ctx, n=6, month_col_index=0)
    if last6 is None or len(last6) < 6:
        return flag("Observed: Insufficient monthly history to compute QoQ revenue growth (need 6 full months).", src)

    # column B index 1
    vals = [_to_float(x) for x in list(last6.iloc[:, 1])]
    months = list(last6["_month"])
    if any(v is None for v in vals):
        return flag("Observed: Missing TotalSales values in 04_L24M_Monthly_Performance_Sum for QoQ computation.", src)

    q0 = sum(vals[-3:])
    q1 = sum(vals[:3])
    if q1 == 0:
        return flag("Observed: Previous-quarter revenue is zero/invalid; QoQ cannot be computed.", src)
    qoq = (q0 - q1) / q1

    flag_th, partial_th = _apply_seasonality_thresholds(ctx, [pd.Timestamp(m) for m in months], base_flag=-0.10, base_partial=-0.05)

    if qoq <= flag_th:
        return flag(f"Observed: Revenue changed {_pct_str(qoq)} comparing the last 3 full months ({_money_str(q1)} → {_money_str(q0)}).", src)
    if qoq <= partial_th:
        return partial(f"Observed: Revenue changed {_pct_str(qoq)} comparing the last 3 full months ({_money_str(q1)} → {_money_str(q0)}).", src)
    return ok(f"Observed: Revenue changed {_pct_str(qoq)} comparing the last 3 full months ({_money_str(q1)} → {_money_str(q0)}).", src)

def eval_C003(ctx: DatabricksContext) -> cfg.ControlResult:
    df = get_dataset(ctx, "YEARLY_KPIS")
    src = "03_Yearly_KPIs_Current_vs_Last_!TotalSales (Row 18 typical) B/C"
    if df is None or df.empty:
        return flag("Observed: Yearly KPI table missing; cannot evaluate YoY revenue growth.", src)

    # By your spec: TotalSales is A18, Current=B18, Previous=C18, Difference=D18
    cur = _read_cell_by_pos(df, "B", 18)
    prev = _read_cell_by_pos(df, "C", 18)
    if cur is None or prev is None or prev == 0:
        return flag("Observed: TotalSales row values missing in 03_Yearly_KPIs_Current_vs_Last_ (B18/C18).", src)

    yoy = (cur - prev) / prev
    if yoy <= -0.10:
        return flag(f"Observed: Revenue changed {_pct_str(yoy)} vs previous period ({_money_str(prev)} → {_money_str(cur)}) based on TotalSales in 03_Yearly_KPIs_Current_vs_Last_.", src)
    if yoy <= -0.05:
        return partial(f"Observed: Revenue changed {_pct_str(yoy)} vs previous period ({_money_str(prev)} → {_money_str(cur)}) based on TotalSales in 03_Yearly_KPIs_Current_vs_Last_.", src)
    return ok(f"Observed: Revenue changed {_pct_str(yoy)} vs previous period ({_money_str(prev)} → {_money_str(cur)}) based on TotalSales in 03_Yearly_KPIs_Current_vs_Last_.", src)

def eval_C004(ctx: DatabricksContext) -> cfg.ControlResult:
    df02 = get_dataset(ctx, "KPI_RANGE")
    src = "02_Date_Range_KPIs__Date_Range_!M7 vs 38_Client_Success_Insights_Repo!O7"
    if df02 is None or df02.empty:
        return flag("Observed: Date range KPI tab missing; cannot evaluate ACoS goal attainment.", src)
    if ctx.acos_constraint is None:
        return flag("Observed: ACoS constraint missing in Client Success (O7).", src)

    actual = _read_cell_by_pos(df02, "M", 7)
    if actual is None:
        return flag("Observed: Current ACoS missing in 02_Date_Range_KPIs__Date_Range_ (M7).", src)

    # normalize % if needed
    if actual > 1:
        actual = actual / 100.0

    target = ctx.acos_constraint
    # only penalize when actual > target
    if actual <= target * 1.05:
        return ok(f"Observed: Current ACoS = {_pct_str(actual)} vs ACoS constraint = {_pct_str(target)}.", src)
    if actual <= target * 1.10:
        over_pp = (actual - target) * 100
        return partial(f"Observed: Current ACoS = {_pct_str(actual)} vs ACoS constraint = {_pct_str(target)} (over by {over_pp:.1f}pp).", src)
    over_pp = (actual - target) * 100
    return flag(f"Observed: Current ACoS = {_pct_str(actual)} vs ACoS constraint = {_pct_str(target)} (over by {over_pp:.1f}pp).", src)


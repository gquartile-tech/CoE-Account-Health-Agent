def eval_C019(ctx: DatabricksContext) -> cfg.ControlResult:
    df46 = get_dataset(ctx, "STRIPE")
    src = "46_Stripe_Payments!C (PaymentDate) — on-time monthly payment compliance"
    if df46 is None or df46.empty:
        return flag("Observed: Stripe payments tab missing; cannot evaluate Financial Risk Indicator.", src)

    # Column C is PaymentDate (excel col C => index 2)
    try:
        pay_dates = pd.to_datetime(df46.iloc[:, 2], errors="coerce")
        pay_dates = pay_dates.dropna()
    except Exception:
        pay_dates = pd.Series([], dtype="datetime64[ns]")

    if pay_dates.empty:
        return flag("Observed: No valid payment dates found in 46_Stripe_Payments column C; cannot evaluate payment punctuality.", src)

    first_payment = pay_dates.min().date()
    billing_day = first_payment.day

    if ctx.ref_date is None:
        # fallback: use max payment date as anchor
        anchor = pay_dates.max().to_period("M").to_timestamp()
    else:
        anchor = pd.Timestamp(ctx.ref_date).to_period("M").to_timestamp()

    # evaluate last 6 months (by month)
    months = [(anchor - pd.offsets.MonthBegin(i)).to_period("M").to_timestamp() for i in range(1, 7)]
    missing_last3 = []
    missing_3to6 = []

    pay_date_set = set(d.date() for d in pay_dates.dt.date)

    for idx, m in enumerate(months, start=1):
        expected = date(m.year, m.month, min(billing_day, 28 if m.month == 2 else 30 if m.month in (4,6,9,11) else 31))
        if expected not in pay_date_set:
            if idx <= 3:
                missing_last3.append(expected.strftime("%Y-%m-%d"))
            else:
                missing_3to6.append(expected.strftime("%Y-%m-%d"))

    what = f"Observed: Billing day is day {billing_day} (first payment: {first_payment}). Missing on-time payments detected in: {missing_last3} (last 3 months), {missing_3to6} (months 3–6)."

    if missing_last3:
        return flag(what, src)
    if missing_3to6:
        return partial(what, src)
    return ok(what, src)


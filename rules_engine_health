def _eval_abs_delta(df03: pd.DataFrame, row: int, label: str, ok_th: float, partial_th: float, src: str, fmt: str = "number") -> cfg.ControlResult:
    d = _read_cell_by_pos(df03, "D", row)
    b = _read_cell_by_pos(df03, "B", row)
    c = _read_cell_by_pos(df03, "C", row)
    if d is None or b is None or c is None:
        return flag(f"Observed: {label} YoY fields missing in 03_Yearly_KPIs_Current_vs_Last_ (B{row}/C{row}/D{row}).", src)

    delta = d  # decimal
    ad = abs(delta)

    if fmt == "pct":
        b_str = _pct_str(b if b <= 1 else b/100)
        c_str = _pct_str(c if c <= 1 else c/100)
    else:
        b_str = _money_str(b) if isinstance(b, (int,float)) else str(b)
        c_str = _money_str(c) if isinstance(c, (int,float)) else str(c)

    if ad <= ok_th:
        return ok(f"Observed: {label} changed {_pct_str(delta)} YoY ({c_str} → {b_str}).", src)
    if ad <= partial_th:
        return partial(f"Observed: {label} changed {_pct_str(delta)} YoY ({c_str} → {b_str}).", src)
    return flag(f"Observed: {label} changed {_pct_str(delta)} YoY ({c_str} → {b_str}).", src)

